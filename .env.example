# Variables de entorno requeridas para ejecutar la aplicacion localmente.
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.

# Base de datos MySQL
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=indecsa
MYSQLUSER=root
MYSQLPASSWORD=tu_password_aqui

# JWT — generar con: openssl rand -base64 32
JWT_SECRET=genera-un-secreto-seguro-de-al-menos-32-bytes

# Puerto del servidor (Railway lo inyecta automaticamente)
PORT=8080
